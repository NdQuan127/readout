<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Readout turns your sources into concise AI summaries and tags."
    />
    <meta property="og:site_name" content="Readout" />
    <meta property="og:title" content="Readout" />
    <meta
      property="og:description"
      content="Concise AI summaries and tags from the sources you follow."
    />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={url(~p"/images/og-image.svg")} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Readout" />
    <meta
      name="twitter:description"
      content="Concise AI summaries and tags from the sources you follow."
    />
    <meta name="twitter:image" content={url(~p"/images/og-image.svg")} />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Readout" suffix="" phx-no-format>{assigns[:page_title]}</.live_title>
    <link rel="icon" type="image/svg+xml" href={~p"/favicon.svg"} />
    <link rel="manifest" href={~p"/site.webmanifest"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    <ul class="menu menu-horizontal w-full relative z-10 flex items-center gap-4 px-4 sm:px-6 lg:px-8 justify-end">
      <%= if @current_scope do %>
        <li>
          {@current_scope.user.email}
        </li>
        <li>
          <.link href={~p"/users/settings"}>Settings</.link>
        </li>
        <li>
          <.link href={~p"/users/log-out"} method="delete">Log out</.link>
        </li>
      <% else %>
        <li>
          <.link href={~p"/users/log-in"}>Log in</.link>
        </li>
      <% end %>
    </ul>
    {@inner_content}
  </body>
</html>
